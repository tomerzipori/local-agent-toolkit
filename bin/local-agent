MODES = tuple(PROMPTS)
COMMANDS = MODES + ("review-staged", "review-branch")


@dataclass(frozen=True)
class Settings:
    model: str
    host: str
    num_ctx: int
    max_chars: int


@dataclass(frozen=True)
class ContextFile:
    path: Path
    relative_path: str
    size_bytes: int
    source: str


@dataclass(frozen=True)
class SkippedFile:
    path: Path
    relative_path: str
    category: str
    detail: str


@dataclass
class ContextCollection:
    text: str
    included: list[ContextFile]
    skipped: list[SkippedFile]
    command_status: int | None


@dataclass(frozen=True)
class RepoInventory:
    tracked: set[Path]
    untracked: set[Path]
    ignored: set[Path]


class UsageError(RuntimeError):
    """Raised for user-facing usage errors that should exit with status 2."""


def config_path() -> Path:
    return Path(os.path.expanduser(str(CONFIG_PATH)))


def load_config() -> dict[str, object]:
    path = config_path()
    if not path.exists():
        return {}
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        raise RuntimeError(
            f"Configuration file {path} is malformed; remove it or run `local-agent configure`."
        ) from exc
    if not isinstance(data, dict):
        raise RuntimeError(
            f"Configuration file {path} must contain a JSON object; run `local-agent configure`."
        )
    return data


def _positive_int(value: object, name: str) -> int:
    try:
        parsed = int(value)
    except (TypeError, ValueError) as exc:
        raise RuntimeError(f"{name} must be a positive integer.") from exc
    if isinstance(value, bool) or parsed <= 0:
        raise RuntimeError(f"{name} must be a positive integer.")
    return parsed


def normalize_host(value: object) -> str:
    if not isinstance(value, str) or not value.strip():
        raise RuntimeError("Ollama host must be a non-empty URL.")
    host = value.strip()
    parsed = urlparse(host)
    if parsed.scheme not in {"http", "https"} or not parsed.netloc:
        raise RuntimeError("Ollama host must be an http:// or https:// URL.")
    if parsed.username is not None or parsed.password is not None:
        raise RuntimeError("Ollama host URLs must not include embedded credentials.")
    if parsed.params or parsed.query or parsed.fragment:
        raise RuntimeError("Ollama host URLs must not include params, query strings, or fragments.")
    if parsed.path not in {"", "/"}:
        raise RuntimeError("Ollama host URLs must not include a path.")
    return host.rstrip("/")


def validate_config(data: dict[str, object]) -> dict[str, object]:
    validated = dict(data)
    raw_version = validated.get("schema_version", 0)
    if isinstance(raw_version, bool) or not isinstance(raw_version, int):
        raise RuntimeError("Configuration schema_version must be an integer.")
    if raw_version > CONFIG_SCHEMA_VERSION:
        raise RuntimeError(
            f"Configuration file {config_path()} uses schema_version {raw_version}, "
            f"but this local-agent supports up to {CONFIG_SCHEMA_VERSION}. Upgrade local-agent first."
        )
    validated["schema_version"] = CONFIG_SCHEMA_VERSION
    if "model" in validated:
        model = validated["model"]
        if not isinstance(model, str):
            raise RuntimeError("Configured model must be a string.")
        if not model:
            raise RuntimeError("Configured model must not be empty.")
    if "host" in validated:
        validated["host"] = normalize_host(validated["host"])
    if "num_ctx" in validated:
        validated["num_ctx"] = _positive_int(validated["num_ctx"], "num_ctx")
    if "max_chars" in validated:
        validated["max_chars"] = _positive_int(validated["max_chars"], "max_chars")
    return validated


def _setting(
    args: argparse.Namespace, config: dict[str, object], name: str, env_name: str, default: object
) -> tuple[object, str]:
    cli_value = getattr(args, name, None)
    if cli_value is not None:
        return cli_value, "cli"
    env_value = os.environ.get(env_name)
    if env_value is not None:
        return env_value, "environment"
    if name in config:
        return config[name], "saved config"
    return default, "default"


def resolve_settings_with_sources(
    args: argparse.Namespace, config: dict[str, object], require_model: bool = True
) -> tuple[Settings, dict[str, str]]:
    model, model_source = _setting(args, config, "model", "LOCAL_AGENT_MODEL", "")
    host, host_source = _setting(args, config, "host", "LOCAL_AGENT_HOST", DEFAULT_HOST)
    num_ctx, num_ctx_source = _setting(args, config, "num_ctx", "LOCAL_AGENT_NUM_CTX", DEFAULT_NUM_CTX)
    max_chars, max_chars_source = _setting(args, config, "max_chars", "LOCAL_AGENT_MAX_CHARS", DEFAULT_MAX_CHARS)
    if require_model and (not isinstance(model, str) or not model):
        raise RuntimeError(
            "No model is configured. Run `local-agent configure`, set LOCAL_AGENT_MODEL, or pass --model."
        )
    if not isinstance(model, str):
        raise RuntimeError("Configured model must be a string.")
    settings = Settings(
        model=model,
        host=normalize_host(host),
        num_ctx=_positive_int(num_ctx, "num_ctx"),
        max_chars=_positive_int(max_chars, "max_chars"),
    )
    return settings, {
        "model": model_source,
        "host": host_source,
        "num_ctx": num_ctx_source,
        "max_chars": max_chars_source,
    }


def resolve_settings(args: argparse.Namespace, config: dict[str, object], require_model: bool = True) -> Settings:
    settings, _ = resolve_settings_with_sources(args, config, require_model=require_model)
    return settings


def save_config(values: dict[str, object]) -> None:
    path = config_path()
    payload = validate_config(values)
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, temp_path = tempfile.mkstemp(prefix=f".{path.name}.", suffix=".tmp", dir=path.parent)
    try:
        os.chmod(temp_path, 0o600)
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            handle.write(json.dumps(payload, indent=2, sort_keys=True) + "\n")
        os.replace(temp_path, path)
        path.chmod(0o600)
    except Exception:
        try:
            os.unlink(temp_path)
        except FileNotFoundError:
            pass
        raise


def update_config(changes: dict[str, object]) -> dict[str, object]:
    config = validate_config(load_config())
    merged = {**config, **changes, "schema_version": CONFIG_SCHEMA_VERSION}
    validated = validate_config(merged)
    save_config(validated)
    return validated


def classify_host(host: str) -> Literal["local", "remote-secure", "remote-insecure"]:
    parsed = urlparse(normalize_host(host))
    hostname = parsed.hostname
    if hostname is None:
        raise RuntimeError("Ollama host must include a hostname.")
    local = False
    if hostname == "localhost":
        local = True
    else:
        try:
            local = ipaddress.ip_address(hostname).is_loopback
        except ValueError:
            local = False
    if local:
        return "local"
    if parsed.scheme == "https":
        return "remote-secure"
    return "remote-insecure"


def ensure_host_allowed(
    host: str, allow_remote_host: bool, allow_insecure_remote_host: bool = False
) -> None:
    classification = classify_host(host)
    if classification == "local":
        return
    if not allow_remote_host:
        raise RuntimeError(
            f"Refusing to connect to non-local Ollama host {host}. "
            "Pass --allow-remote-host only when sending repository content to that server is intentional."
        )
    if classification == "remote-insecure" and not allow_insecure_remote_host:
        raise RuntimeError(
            f"Refusing insecure remote Ollama host {host}. "
            "Pass --allow-insecure-remote-host only when plain HTTP to that remote server is intentional."
        )


def request_json(
    host: str,
    endpoint: str,
    payload: dict[str, object] | None = None,
    allow_remote_host: bool = False,
    allow_insecure_remote_host: bool = False,
) -> dict[str, object]:
    ensure_host_allowed(
        host,
        allow_remote_host=allow_remote_host,
        allow_insecure_remote_host=allow_insecure_remote_host,
    )
    data = None if payload is None else json.dumps(payload).encode("utf-8")
    request = urllib.request.Request(
        host.rstrip("/") + endpoint,
        data=data,
        headers={"Content-Type": "application/json"} if data is not None else {},
        method="POST" if data is not None else "GET",
    )
    try:
        with urllib.request.urlopen(request, timeout=3600) as response:
            raw = response.read(MAX_OLLAMA_RESPONSE_BYTES + 1)
            if len(raw) > MAX_OLLAMA_RESPONSE_BYTES:
                raise RuntimeError(
                    f"Ollama returned more than {MAX_OLLAMA_RESPONSE_BYTES} bytes at {host}{endpoint}."
                )
            result = json.loads(raw.decode("utf-8"))
    except urllib.error.HTTPError as exc:
        detail = exc.read().decode("utf-8", errors="replace")
        raise RuntimeError(f"Ollama returned HTTP {exc.code} at {host}{endpoint}: {detail}") from exc
    except (urllib.error.URLError, TimeoutError, OSError) as exc:
        raise RuntimeError(
            f"Could not reach Ollama at {host}. Start Ollama and verify the host is correct. ({exc})"
        ) from exc
    except (UnicodeDecodeError, json.JSONDecodeError) as exc:
        raise RuntimeError(f"Ollama returned invalid JSON at {host}{endpoint}.") from exc
    if not isinstance(result, dict):
        raise RuntimeError(f"Ollama returned an unexpected response at {host}{endpoint}.")
    if "error" in result:
        raise RuntimeError(f"Ollama error at {host}{endpoint}: {result['error']}")
    return result


def discover_models(
    host: str, allow_remote_host: bool = False, allow_insecure_remote_host: bool = False
) -> list[str]:
    result = request_json(
        host,
        "/api/tags",
        allow_remote_host=allow_remote_host,
        allow_insecure_remote_host=allow_insecure_remote_host,
    )
    raw_models = result.get("models", [])
    if not isinstance(raw_models, list):
        raise RuntimeError("Ollama returned an invalid model list.")
    names = [item.get("name") for item in raw_models if isinstance(item, dict) and item.get("name")]
    if not names:
        raise RuntimeError(
            f"No Ollama models are installed at {host}. Run `ollama pull <model>` and try again."
        )
    return [str(name) for name in names]


def _model_details(value: object) -> dict[str, object]:
    return value if isinstance(value, dict) else {}


def _context_length(model_info: object) -> int | None:
    if not isinstance(model_info, dict):
        return None
    for key, value in model_info.items():
        if str(key).endswith(".context_length") and isinstance(value, int) and not isinstance(value, bool):
            return value
    return None


def model_inventory(
    host: str, allow_remote_host: bool = False, allow_insecure_remote_host: bool = False
) -> list[dict[str, object]]:
    result = request_json(
        host,
        "/api/tags",
        allow_remote_host=allow_remote_host,
        allow_insecure_remote_host=allow_insecure_remote_host,
    )
    raw_models = result.get("models", [])
    if not isinstance(raw_models, list):
        raise RuntimeError("Ollama returned an invalid model list.")
    tagged_models = [item for item in raw_models if isinstance(item, dict) and item.get("name")]
    if not tagged_models:
        raise RuntimeError(
            f"No Ollama models are installed at {host}. Run `ollama pull <model>` and try again."
        )

    inventory: list[dict[str, object]] = []
    for tagged in tagged_models:
        name = str(tagged["name"])
        tagged_details = _model_details(tagged.get("details"))
        shown = request_json(
            host,
            "/api/show",
            {"model": name},
            allow_remote_host=allow_remote_host,
            allow_insecure_remote_host=allow_insecure_remote_host,
        )
        shown_details = _model_details(shown.get("details"))
        details = {**tagged_details, **shown_details}
        families = details.get("families")
        capabilities = shown.get("capabilities")
        inventory.append({
            "name": name,
            "size_bytes": tagged.get("size") if isinstance(tagged.get("size"), int) else None,
            "family": details.get("family") if isinstance(details.get("family"), str) else None,
            "families": families if isinstance(families, list) else [],
            "parameter_size": (
                details.get("parameter_size") if isinstance(details.get("parameter_size"), str) else None
            ),
            "quantization": (
                details.get("quantization_level")
                if isinstance(details.get("quantization_level"), str)
                else None
            ),
            "capabilities": capabilities if isinstance(capabilities, list) else [],
            "context_length": _context_length(shown.get("model_info")),
        })
    return inventory


def select_model(models: list[str], saved: str | None = None) -> str:
    print("Installed Ollama models:")
    for index, name in enumerate(models, 1):
        marker = " (current)" if name == saved else ""
        print(f"  {index}. {name}{marker}")
    while True:
        choice = input("Select a default model by number or exact name: ").strip()
        if choice.isdigit() and 1 <= int(choice) <= len(models):
            return models[int(choice) - 1]
        if choice in models:
            return choice
        print("Enter one of the listed numbers or exact model names.", file=sys.stderr)


def any_config_flags_supplied(args: argparse.Namespace) -> bool:
    return any(getattr(args, name, None) is not None for name in CONFIG_FIELDS)


def print_config(settings: Settings, sources: dict[str, str]) -> None:
    values = {
        "model": settings.model or "(unset)",
        "host": settings.host,
        "num_ctx": settings.num_ctx,
        "max_chars": settings.max_chars,
    }
    print("Effective local-agent configuration:")
    for name in CONFIG_FIELDS:
        print(f"  {name}: {values[name]} [{sources[name]}]")


def run_git(args: list[str]) -> str:
    result = subprocess.run(["git", *args], text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
    if result.returncode:
        raise RuntimeError(result.stderr.strip() or f"git {' '.join(args)} failed")
    return result.stdout


def run_git_bytes(args: list[str], cwd: Path) -> bytes:
    result = subprocess.run(["git", *args], cwd=cwd, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
    if result.returncode:
        message = result.stderr.decode("utf-8", errors="replace").strip()
        raise RuntimeError(message or f"git {' '.join(args)} failed")
    return result.stdout


def repo_root() -> Path:
    return Path(run_git(["rev-parse", "--show-toplevel"]).strip()).resolve()


def ensure_repo() -> Path:
    try:
        return repo_root()
    except RuntimeError as exc:
        raise RuntimeError("This command must be run inside a Git repository.") from exc


def checked_path(raw: str, root: Path | None, allow_outside: bool) -> Path:
    path = Path(raw).expanduser()
    absolute = path if path.is_absolute() else (Path.cwd() / path)
    resolved = absolute.parent.resolve(strict=False) / absolute.name
    if root is not None:
        try:
            resolved.relative_to(root)
        except ValueError:
            if not allow_outside:
                raise RuntimeError(
                    f"Refusing file outside the current repository: {raw}. "
                    "Use --allow-outside-repo only when this is intentional."
                )
    return resolved


def _git_paths(root: Path, args: list[str]) -> set[Path]:
    output = run_git_bytes(args + ["-z"], cwd=root)
    if not output:
        return set()
    return {
        (root / entry.decode("utf-8", errors="surrogateescape")).resolve(strict=False)
        for entry in output.split(b"\0")
        if entry
    }


def tracked_files(root: Path) -> set[Path]:
    return _git_paths(root, ["ls-files"])


def untracked_files(root: Path) -> set[Path]:
    return _git_paths(root, ["ls-files", "--others", "--exclude-standard"])


def ignored_files(root: Path) -> set[Path]:
    return _git_paths(root, ["ls-files", "--others", "--ignored", "--exclude-standard"])


def build_repo_inventory(root: Path) -> RepoInventory:
    return RepoInventory(
        tracked=tracked_files(root),
        untracked=untracked_files(root),
        ignored=ignored_files(root),
    )


def relative_label(path: Path, root: Path | None) -> str:
    if root is None:
        return str(path)
    try:
        return str(path.relative_to(root))
    except ValueError:
        return str(path)


def is_sensitive_path(path: Path, root: Path | None) -> bool:
    label = relative_label(path, root).replace("\\", "/")
    name = path.name
    if name in SENSITIVE_BASENAMES:
        return True
    if label in SENSITIVE_PATHS:
        return True
    return any(fnmatch.fnmatch(label, pattern) or fnmatch.fnmatch(name, pattern) for pattern in SENSITIVE_GLOBS)


def format_bytes(size: int) -> str:
    if size < 1024:
        return f"{size} B"
    units = ("KB", "MB", "GB")
    value = float(size)
    for unit in units:
        value /= 1024.0
        if value < 1024.0 or unit == units[-1]:
            return f"{value:.1f} {unit}"
    return f"{size} B"


def classify_candidate(
    path: Path, root: Path | None, inventory: RepoInventory | None, explicit: bool
) -> tuple[str, str]:
    label = relative_label(path, root)
    if inventory is None:
        return "explicit", label
    if path in inventory.ignored:
        return "ignored", label
    if path in inventory.untracked:
        return "untracked", label
    if path in inventory.tracked:
        return ("explicit" if explicit else "tracked-directory"), label
    return "explicit", label


def is_binary(path: Path) -> bool:
    try:
        with path.open("rb") as handle:
            return b"\0" in handle.read(8192)
    except OSError:
        return False


def validate_candidate(
    path: Path,
    root: Path | None,
    source: str,
    *,
    include_untracked: bool,
    include_ignored: bool,
    allow_sensitive_files: bool,
    max_file_bytes: int,
) -> tuple[ContextFile | None, SkippedFile | None]:
    label = relative_label(path, root)
    if path.is_symlink():
        return None, SkippedFile(path, label, "symlink", "symlinked files are never followed")
    try:
        stat_result = path.stat()
    except OSError as exc:
        return None, SkippedFile(path, label, "unreadable", str(exc))
    if not path.is_file():
        return None, SkippedFile(path, label, "non-file", "not a regular file")
    if source == "untracked" and not include_untracked:
        return None, SkippedFile(path, label, "untracked", "pass --include-untracked to include it")
    if source == "ignored" and not include_ignored:
        return None, SkippedFile(path, label, "ignored", "pass --include-ignored to include it")
    if is_sensitive_path(path, root) and not allow_sensitive_files:
        return None, SkippedFile(
            path,
            label,
            "sensitive",
            "pass --allow-sensitive-files to include it",
        )
    if stat_result.st_size > max_file_bytes:
        return None, SkippedFile(
            path,
            label,
            "oversized",
            f"{format_bytes(stat_result.st_size)} exceeds --max-file-bytes={max_file_bytes}",
        )
    if is_binary(path):
        return None, SkippedFile(path, label, "binary", "binary files are skipped")
    return ContextFile(path, label, stat_result.st_size, source), None


def candidate_sort_key(path: Path, root: Path | None) -> str:
    return relative_label(path, root)


def collect_candidate_files(
    paths: Iterable[str],
    *,
    root: Path | None,
    inventory: RepoInventory | None,
    allow_outside_repo: bool,
    include_untracked: bool,
    include_ignored: bool,
    allow_sensitive_files: bool,
    max_file_bytes: int,
    max_context_files: int,
    allow_directory_recursion: bool,
) -> tuple[list[ContextFile], list[SkippedFile]]:
    included: list[ContextFile] = []
    skipped: list[SkippedFile] = []
    seen: set[Path] = set()

    def add_candidate(path: Path, explicit: bool) -> None:
        if path in seen:
            return
        seen.add(path)
        source, _label = classify_candidate(path, root, inventory, explicit=explicit)
        context_file, skipped_file = validate_candidate(
            path,
            root,
            source,
            include_untracked=include_untracked,
            include_ignored=include_ignored,
            allow_sensitive_files=allow_sensitive_files,
            max_file_bytes=max_file_bytes,
        )
        if skipped_file is not None:
            skipped.append(skipped_file)
            return
        assert context_file is not None
        if len(included) >= max_context_files:
            skipped.append(
                SkippedFile(
                    context_file.path,
                    context_file.relative_path,
                    "file-limit",
                    f"reached --max-context-files={max_context_files}",
                )
            )
            return
        included.append(context_file)

    for raw in paths:
        resolved = checked_path(raw, root, allow_outside_repo)
        label = relative_label(resolved, root)
        if not resolved.exists():
            skipped.append(SkippedFile(resolved, label, "missing", "path does not exist"))
            continue
        if resolved.is_dir():
            if not allow_directory_recursion:
                raise RuntimeError(
                    "Directory recursion is not supported outside a Git repository for diagnose. Pass files explicitly."
                )
            if root is None:
                raise RuntimeError("Directory context requires a Git repository.")
            try:
                resolved.relative_to(root)
            except ValueError as exc:
                raise RuntimeError("Directory context must stay inside the current repository.") from exc
            assert inventory is not None
            candidates = sorted(
                (
                    path
                    for group in (inventory.tracked, inventory.untracked, inventory.ignored)
                    for path in group
                    if path.is_relative_to(resolved)
                ),
                key=lambda item: candidate_sort_key(item, root),
            )
            for candidate in candidates:
                add_candidate(candidate, explicit=False)
            continue
        add_candidate(resolved, explicit=True)

    return included, skipped


def append_with_budget(parts: list[str], text: str, remaining_chars: int) -> int:
    if remaining_chars <= 0 or not text:
        return remaining_chars
    chunk = text[:remaining_chars]
    parts.append(chunk)
    return remaining_chars - len(chunk)


def read_text_limited(path: Path, char_limit: int) -> tuple[str, bool]:
    if char_limit <= 0:
        return "", False
    try:
        with path.open("r", encoding="utf-8") as handle:
            text = handle.read(char_limit + 1)
    except (OSError, UnicodeDecodeError) as exc:
        raise RuntimeError(str(exc)) from exc
    truncated = len(text) > char_limit
    return text[:char_limit], truncated


def add_context_files(
    parts: list[str],
    files: Iterable[ContextFile],
    collection: ContextCollection,
    remaining_chars: int,
) -> tuple[list[ContextFile], int]:
    retained: list[ContextFile] = []
    for context_file in files:
        if remaining_chars <= 0:
            collection.skipped.append(
                SkippedFile(
                    context_file.path,
                    context_file.relative_path,
                    "context-budget",
                    "context character budget exhausted before reading file",
                )
            )
            continue
        header = f"\n===== FILE: {context_file.relative_path} =====\n"
        if len(header) > remaining_chars:
            collection.skipped.append(
                SkippedFile(
                    context_file.path,
                    context_file.relative_path,
                    "context-budget",
                    "context character budget exhausted before reading file",
                )
            )
            continue
        remaining_chars = append_with_budget(parts, header, remaining_chars)
        try:
            content, truncated = read_text_limited(context_file.path, remaining_chars)
        except RuntimeError as exc:
            collection.skipped.append(
                SkippedFile(
                    context_file.path,
                    context_file.relative_path,
                    "unreadable",
                    str(exc),
                )
            )
            parts.pop()
            remaining_chars += len(header)
            continue
        if not content and truncated:
            collection.skipped.append(
                SkippedFile(
                    context_file.path,
                    context_file.relative_path,
                    "context-budget",
                    "context character budget exhausted before reading file",
                )
            )
            parts.pop()
            remaining_chars += len(header)
            continue
        remaining_chars = append_with_budget(parts, content, remaining_chars)
        if truncated:
            marker = f"\n[... FILE TRUNCATED: {context_file.relative_path} ...]\n"
            remaining_chars = append_with_budget(parts, marker, remaining_chars)
        retained.append(context_file)
    return retained, remaining_chars


def search_repository(files: Iterable[ContextFile], terms: Iterable[str], remaining_chars: int) -> tuple[list[str], int]:
    matches: list[str] = []
    for context_file in files:
        if remaining_chars <= 0:
            break
        try:
            content, _ = read_text_limited(context_file.path, min(context_file.size_bytes, remaining_chars))
        except RuntimeError:
            continue
        for line_number, line in enumerate(content.splitlines(), 1):
            if any(term in line for term in terms):
                rendered = f"{context_file.relative_path}:{line_number}:{line}\n"
                if len(rendered) > remaining_chars:
                    return matches, 0
                matches.append(rendered.rstrip("\n"))
                remaining_chars -= len(rendered)
    return matches, remaining_chars


def truncate_context(text: str, limit: int) -> tuple[str, bool]:
    if len(text) <= limit:
        return text, False
    half = max(1, (limit - 80) // 2)
    marker = f"\n\n[... CONTEXT TRUNCATED TO {limit} CHARACTERS ...]\n\n"
    return text[:half] + marker + text[-half:], True


def default_base() -> str:
    try:
        remote_head = run_git(["symbolic-ref", "--quiet", "--short", "refs/remotes/origin/HEAD"]).strip()
        if remote_head:
            return remote_head
    except RuntimeError:
        pass
    for candidate in ("main", "master"):
        try:
            run_git(["rev-parse", "--verify", candidate])
            return candidate
        except RuntimeError:
            continue
    raise RuntimeError("Could not determine a base branch; pass --base <branch> explicitly.")


def _flag(args: argparse.Namespace, name: str, default: bool = False) -> bool:
    return bool(getattr(args, name, default))


def _int_arg(args: argparse.Namespace, name: str, default: int) -> int:
    value = getattr(args, name, None)
    return default if value is None else int(value)


def gather_repo_candidates(root: Path, args: argparse.Namespace) -> tuple[list[ContextFile], list[SkippedFile], RepoInventory]:
    inventory = build_repo_inventory(root)
    included, skipped = collect_candidate_files(
        [str(root)],
        root=root,
        inventory=inventory,
        allow_outside_repo=False,
        include_untracked=_flag(args, "include_untracked"),
        include_ignored=_flag(args, "include_ignored"),
        allow_sensitive_files=_flag(args, "allow_sensitive_files"),
        max_file_bytes=_int_arg(args, "max_file_bytes", DEFAULT_MAX_FILE_BYTES),
        max_context_files=_int_arg(args, "max_context_files", DEFAULT_MAX_CONTEXT_FILES),
        allow_directory_recursion=True,
    )
    return included, skipped, inventory


def render_context_manifest(collection: ContextCollection) -> str:
    lines = [
        f"included files: {len(collection.included)}",
        f"skipped files: {len(collection.skipped)}",
    ]
    for item in collection.included:
        lines.append(
            f"included {item.source}: {item.relative_path} ({format_bytes(item.size_bytes)})"
        )
    for item in collection.skipped:
        lines.append(f"skipped {item.category}: {item.relative_path} ({item.detail})")
    return "\n".join(lines) + "\n"


def collect_context(args: argparse.Namespace, context_limit: int | None = None) -> ContextCollection:
    if context_limit is None:
        context_limit = _int_arg(args, "max_chars", DEFAULT_MAX_CHARS)
    parts: list[str] = []
    collection = ContextCollection(text="", included=[], skipped=[], command_status=None)
    remaining_chars = context_limit

    needs_repo = args.mode in {"find", "review", "review-staged", "review-branch", "impact"} or (
        args.files and args.mode != "diagnose"
    )
    if needs_repo:
        root = ensure_repo()
        inventory = build_repo_inventory(root)
    elif args.mode == "diagnose" and args.files:
        root = None
        inventory = None
    else:
        root = ensure_repo() if args.mode in {"find", "impact"} else None
        inventory = build_repo_inventory(root) if root is not None else None

    if _flag(args, "stdin"):
        piped = sys.stdin.read()
        if piped:
            remaining_chars = append_with_budget(parts, "\n===== STDIN =====\n", remaining_chars)
            remaining_chars = append_with_budget(parts, piped, remaining_chars)

    explicit_included: list[ContextFile] = []
    if args.files:
        allow_directory_recursion = not (args.mode == "diagnose" and root is None)
        included, skipped = collect_candidate_files(
            args.files,
            root=root,
            inventory=inventory,
            allow_outside_repo=_flag(args, "allow_outside_repo"),
            include_untracked=_flag(args, "include_untracked"),
            include_ignored=_flag(args, "include_ignored"),
            allow_sensitive_files=_flag(args, "allow_sensitive_files"),
            max_file_bytes=_int_arg(args, "max_file_bytes", DEFAULT_MAX_FILE_BYTES),
            max_context_files=_int_arg(args, "max_context_files", DEFAULT_MAX_CONTEXT_FILES),
            allow_directory_recursion=allow_directory_recursion,
        )
        collection.included.extend(included)
        explicit_included.extend(included)
        collection.skipped.extend(skipped)

    repo_candidates: list[ContextFile] = []
    if args.mode in {"find", "impact"}:
        assert root is not None
        if inventory is None:
            inventory = build_repo_inventory(root)
        repo_candidates, repo_skipped = collect_candidate_files(
            [str(root)],
            root=root,
            inventory=inventory,
            allow_outside_repo=False,
            include_untracked=_flag(args, "include_untracked"),
            include_ignored=_flag(args, "include_ignored"),
            allow_sensitive_files=_flag(args, "allow_sensitive_files"),
            max_file_bytes=_int_arg(args, "max_file_bytes", DEFAULT_MAX_FILE_BYTES),
            max_context_files=_int_arg(args, "max_context_files", DEFAULT_MAX_CONTEXT_FILES),
            allow_directory_recursion=True,
        )
        existing_paths = {existing.path for existing in collection.included}
        for item in repo_candidates:
            if item.path not in existing_paths:
                collection.included.append(item)
                existing_paths.add(item.path)
        for item in repo_skipped:
            if (item.path, item.category, item.detail) not in {
                (existing.path, existing.category, existing.detail) for existing in collection.skipped
            }:
                collection.skipped.append(item)

    retained_explicit, remaining_chars = add_context_files(parts, explicit_included, collection, remaining_chars)
    if explicit_included:
        retained_paths = {item.path for item in retained_explicit}
        collection.included = [
            item
            for item in collection.included
            if item.path in retained_paths or item.path in {candidate.path for candidate in repo_candidates}
        ]

    if args.mode == "find":
        file_list = "\n".join(item.relative_path for item in repo_candidates)
        remaining_chars = append_with_budget(parts, "\n===== REPOSITORY FILE LIST =====\n", remaining_chars)
        remaining_chars = append_with_budget(parts, file_list, remaining_chars)
        terms = [term for term in args.task.replace("/", " ").split() if len(term) >= 4][:8]
        matches, remaining_chars = search_repository(repo_candidates, terms, remaining_chars)
        if matches:
            remaining_chars = append_with_budget(parts, "\n===== REPOSITORY SEARCH =====\n", remaining_chars)
            remaining_chars = append_with_budget(parts, "\n".join(matches), remaining_chars)
    elif args.mode == "review-staged":
        remaining_chars = append_with_budget(parts, "\n===== STAGED DIFF =====\n", remaining_chars)
        remaining_chars = append_with_budget(
            parts,
            run_git(["diff", "--cached", "--no-ext-diff", "--unified=60"]),
            remaining_chars,
        )
    elif args.mode == "review-branch":
        base = args.base or default_base()
        remaining_chars = append_with_budget(parts, f"\n===== DIFF AGAINST {base} =====\n", remaining_chars)
        remaining_chars = append_with_budget(
            parts,
            run_git(["diff", f"{base}...HEAD", "--no-ext-diff", "--unified=60"]),
            remaining_chars,
        )
    elif args.mode == "review":
        unstaged = run_git(["diff", "--no-ext-diff", "--unified=60"])
        staged = run_git(["diff", "--cached", "--no-ext-diff", "--unified=60"])
        if unstaged:
            remaining_chars = append_with_budget(parts, "\n===== UNSTAGED DIFF =====\n", remaining_chars)
            remaining_chars = append_with_budget(parts, unstaged, remaining_chars)
        if staged:
            remaining_chars = append_with_budget(parts, "\n===== STAGED DIFF =====\n", remaining_chars)
            remaining_chars = append_with_budget(parts, staged, remaining_chars)
    elif args.mode == "impact":
        file_list = "\n".join(item.relative_path for item in repo_candidates)
        remaining_chars = append_with_budget(parts, "\n===== REPOSITORY FILE LIST =====\n", remaining_chars)
        remaining_chars = append_with_budget(parts, file_list, remaining_chars)
        terms = [term for term in args.task.replace("/", " ").split() if len(term) >= 4][:8]
        matches, remaining_chars = search_repository(repo_candidates, terms, remaining_chars)
        if matches:
            remaining_chars = append_with_budget(parts, "\n===== REPOSITORY SEARCH =====\n", remaining_chars)
            remaining_chars = append_with_budget(parts, "\n".join(matches), remaining_chars)
        unstaged = run_git(["diff", "--no-ext-diff", "--unified=60"])
        staged = run_git(["diff", "--cached", "--no-ext-diff", "--unified=60"])
        if unstaged:
            remaining_chars = append_with_budget(parts, "\n===== UNSTAGED DIFF =====\n", remaining_chars)
            remaining_chars = append_with_budget(parts, unstaged, remaining_chars)
        if staged:
            remaining_chars = append_with_budget(parts, "\n===== STAGED DIFF =====\n", remaining_chars)
            remaining_chars = append_with_budget(parts, staged, remaining_chars)
    elif args.mode == "fix-test":
        if not args.command:
            raise RuntimeError("fix-test requires --command.")
        print(f"Executing local shell command for fix-test: {args.command}", file=sys.stderr)
        completed = subprocess.run(args.command, shell=True, text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)
        collection.command_status = completed.returncode
        remaining_chars = append_with_budget(
            parts,
            f"\n===== LOCAL TEST COMMAND (EXECUTED) =====\n{args.command}\n",
            remaining_chars,
        )
        remaining_chars = append_with_budget(parts, "\n===== TEST OUTPUT =====\n", remaining_chars)
        remaining_chars = append_with_budget(parts, completed.stdout, remaining_chars)
        remaining_chars = append_with_budget(
            parts,
            f"\n===== EXIT CODE: {completed.returncode} =====\n",
            remaining_chars,
        )

    collection.text = "".join(parts)
    return collection


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="local-agent", description="Delegate bounded coding work to an Ollama model.")
    parser.add_argument("--version", action="version", version=f"local-agent {VERSION}")
    subparsers = parser.add_subparsers(dest="mode", required=True)
    for mode in COMMANDS:
        prompt_mode = "review" if mode in {"review-staged", "review-branch"} else mode
        subparser = subparsers.add_parser(mode, help=PROMPTS[prompt_mode].splitlines()[0])
        subparser.add_argument("task", nargs="?", default="")
        subparser.add_argument("files", nargs="*")
        subparser.add_argument("--model")
        subparser.add_argument("--host")
        subparser.add_argument("--num-ctx", type=int)
        subparser.add_argument("--max-chars", type=int)
        subparser.add_argument("--max-file-bytes", type=int, default=DEFAULT_MAX_FILE_BYTES)
        subparser.add_argument("--max-context-files", type=int, default=DEFAULT_MAX_CONTEXT_FILES)
        subparser.add_argument("--allow-remote-host", action="store_true")
        subparser.add_argument("--allow-insecure-remote-host", action="store_true")
        subparser.add_argument("--allow-outside-repo", action="store_true")
        subparser.add_argument("--include-untracked", action="store_true")
        subparser.add_argument("--include-ignored", action="store_true")
        subparser.add_argument("--allow-sensitive-files", action="store_true")
        subparser.add_argument("--show-context-files", action="store_true")
        subparser.add_argument("--stdin", action="store_true")
        subparser.add_argument("--save")
        if mode == "review-branch":
            subparser.add_argument("--base")
        if mode == "fix-test":
            subparser.add_argument("--command")
    configure = subparsers.add_parser("configure", help="Select and save a default installed Ollama model.")
    configure.add_argument("--host")
    configure.add_argument("--model")
    configure.add_argument("--num-ctx", type=int)
    configure.add_argument("--max-chars", type=int)
    configure.add_argument("--allow-remote-host", action="store_true")
    configure.add_argument("--allow-insecure-remote-host", action="store_true")
    configure.add_argument("--show", action="store_true")
    models = subparsers.add_parser("models", help="List models installed in Ollama.")
    models.add_argument("--json", action="store_true", dest="as_json")
    models.add_argument("--host")
    models.add_argument("--model")
    models.add_argument("--num-ctx", type=int)
    models.add_argument("--max-chars", type=int)
    models.add_argument("--allow-remote-host", action="store_true")
    models.add_argument("--allow-insecure-remote-host", action="store_true")
    return parser


def call_ollama(
    prompt: str, settings: Settings, allow_remote_host: bool = False, allow_insecure_remote_host: bool = False
) -> str:
    installed = discover_models(
        settings.host,
        allow_remote_host=allow_remote_host,
        allow_insecure_remote_host=allow_insecure_remote_host,
    )
    if settings.model not in installed:
        raise RuntimeError(
            f"Configured model `{settings.model}` is not installed at {settings.host}. "
            "Run `local-agent models` or `local-agent configure`, or pass --model."
        )
    result = request_json(
        settings.host,
        "/api/generate",
        {
            "model": settings.model,
            "system": SYSTEM_PROMPT,
            "prompt": prompt,
            "stream": False,
            "options": {"num_ctx": settings.num_ctx, "temperature": 0.1},
        },
        allow_remote_host=allow_remote_host,
        allow_insecure_remote_host=allow_insecure_remote_host,
    )
    response = result.get("response")
    if not isinstance(response, str):
        raise RuntimeError("Ollama returned no text response.")
    return response.strip()


def build_prompt(mode: str, task: str, context: str, max_chars: int) -> tuple[str, bool]:
    prompt_key = "review" if mode in {"review-staged", "review-branch"} else mode
    prompt = PROMPTS[prompt_key].format(task=task or "Analyze the supplied context.")
    prompt += "\n\nSUPPLIED CONTEXT:\n"
    context, truncated = truncate_context(context, max_chars)
    if truncated:
        prompt += f"[NOTICE: supplied context was truncated at {max_chars} characters.]\n"
    return prompt + context, truncated


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    try:
        config = validate_config(load_config())
        if args.mode == "models":
            settings = resolve_settings(args, config, require_model=False)
            if args.as_json:
                print(json.dumps({
                    "schema_version": MODELS_JSON_SCHEMA_VERSION,
                    "host": settings.host,
                    "default_model": settings.model or None,
                    "models": model_inventory(
                        settings.host,
                        allow_remote_host=args.allow_remote_host,
                        allow_insecure_remote_host=args.allow_insecure_remote_host,
                    ),
                }, indent=2, sort_keys=True))
                return 0
            for model in discover_models(
                settings.host,
                allow_remote_host=args.allow_remote_host,
                allow_insecure_remote_host=args.allow_insecure_remote_host,
            ):
                print(model)
            return 0
        if args.mode == "configure":
            settings, sources = resolve_settings_with_sources(args, config, require_model=False)
            if args.show:
                print_config(settings, sources)
                return 0
            if any_config_flags_supplied(args):
                models = discover_models(
                    settings.host,
                    allow_remote_host=args.allow_remote_host,
                    allow_insecure_remote_host=args.allow_insecure_remote_host,
                )
                if settings.model:
                    if settings.model not in models:
                        raise RuntimeError(
                            f"Configured model `{settings.model}` is not installed at {settings.host}. "
                            "Run `local-agent models` or `ollama pull <model>`, or pick an installed model."
                        )
                updated = update_config({
                    "model": settings.model,
                    "host": settings.host,
                    "num_ctx": settings.num_ctx,
                    "max_chars": settings.max_chars,
                })
                print(f"Saved configuration to {config_path()} for model {updated.get('model', '(unset)')}")
                return 0
            if not sys.stdin.isatty() or not sys.stdout.isatty():
                raise UsageError("configure requires explicit options in a noninteractive environment")
            models = discover_models(
                settings.host,
                allow_remote_host=args.allow_remote_host,
                allow_insecure_remote_host=args.allow_insecure_remote_host,
            )
            selected = select_model(models, settings.model or None)
            update_config({
                "model": selected,
                "host": settings.host,
                "num_ctx": settings.num_ctx,
                "max_chars": settings.max_chars,
            })
            print(f"Saved configuration to {config_path()} for model {selected}")
            return 0
        settings = resolve_settings(args, config)
        ensure_host_allowed(
            settings.host,
            allow_remote_host=args.allow_remote_host,
            allow_insecure_remote_host=args.allow_insecure_remote_host,
        )
        collection = collect_context(args, context_limit=settings.max_chars)
        if not collection.text and not args.task:
            raise RuntimeError("No task or context was supplied.")
        if _flag(args, "show_context_files"):
            print(render_context_manifest(collection), end="")
            if collection.command_status:
                print(f"local-agent: fix-test command exited with status {collection.command_status}", file=sys.stderr)
                return collection.command_status
            return 0
        print(
            f"local-agent: sending {len(collection.included)} files, {len(collection.text):,} characters to model {settings.model}",
            file=sys.stderr,
        )
        if collection.skipped:
            print(
                f"local-agent: skipped {len(collection.skipped)} files; use --show-context-files for details",
                file=sys.stderr,
            )
        prompt, _ = build_prompt(args.mode, args.task, collection.text, settings.max_chars)
        result = call_ollama(
            prompt,
            settings,
            allow_remote_host=args.allow_remote_host,
            allow_insecure_remote_host=args.allow_insecure_remote_host,
        )
        if args.save:
            save_path = Path(args.save)
            save_path.parent.mkdir(parents=True, exist_ok=True)
            save_path.write_text(result + "\n", encoding="utf-8")
        print(result)
        if collection.command_status:
            print(f"local-agent: fix-test command exited with status {collection.command_status}", file=sys.stderr)
            return collection.command_status
        return 0
    except BrokenPipeError:
        return 0
    except KeyboardInterrupt:
        return 130
    except (RuntimeError, OSError) as exc:
        print(f"local-agent: {exc}", file=sys.stderr)
        return 2 if isinstance(exc, UsageError) else 1


if __name__ == "__main__":
    raise SystemExit(main())
