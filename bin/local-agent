#!/usr/bin/env python3
"""A dependency-free macOS CLI for bounded local-model coding assistance."""
from __future__ import annotations

import argparse
import fnmatch
import ipaddress
import json
import os
import subprocess
import sys
import tempfile
import urllib.error
import urllib.request
from dataclasses import dataclass
from pathlib import Path
from typing import Iterable, Literal
from urllib.parse import urlparse

VERSION = "0.1.0"
DEFAULT_HOST = "http://127.0.0.1:11434"
DEFAULT_NUM_CTX = 32768
DEFAULT_MAX_CHARS = 120_000
DEFAULT_MAX_FILE_BYTES = 256_000
DEFAULT_MAX_CONTEXT_FILES = 200
MAX_OLLAMA_RESPONSE_BYTES = 5_000_000
CONFIG_SCHEMA_VERSION = 1
MODELS_JSON_SCHEMA_VERSION = 1
CONFIG_PATH = Path("~/.config/local-agent/config.json")
CONFIG_FIELDS = ("model", "host", "num_ctx", "max_chars")
SENSITIVE_BASENAMES = {
    ".env",
    "id_rsa",
    "id_ed25519",
    "credentials.json",
    ".netrc",
    "npmrc",
    ".npmrc",
    "pypirc",
    ".pypirc",
}
SENSITIVE_GLOBS = (
    ".env.*",
    "*.pem",
    "*.key",
    "*.p12",
    "*.pfx",
    "secrets.*",
    ".ssh/*",
)
SENSITIVE_PATHS = {".aws/credentials"}

