@dataclass(frozen=True)
class QuantizationInfo:
    raw: str | None
    approximate_bits: float | None
    quality_rank: int | None


@dataclass(frozen=True)
class InstalledModel:
    name: str
    digest: str | None
    size_bytes: int | None
    family: str | None
    families: tuple[str, ...]
    parameter_size: str | None
    parameter_count: int | None
    quantization: str | None
    capabilities: tuple[str, ...]
    context_length: int | None
    coding_signal: str
    base_model_key: str | None
    quantization_rank: int | None
    kv_bytes_per_token_f16: int | None


@dataclass(frozen=True)
class RunningModel:
    name: str
    digest: str | None
    loaded_size_bytes: int | None
    loaded_vram_bytes: int | None
    loaded_context_length: int | None
    expires_at: str | None


@dataclass(frozen=True)
class SystemMemory:
    platform: str
    architecture: str
    memory_model: str
    total_bytes: int | None
    available_bytes: int | None
    protected_reserve_bytes: int | None
    model_budget_bytes: int | None
    confidence: str
    warnings: tuple[str, ...]


@dataclass(frozen=True)
class ModelMemoryEstimate:
    status: str
    weights_bytes: int | None
    runtime_overhead_bytes: int | None
    kv_cache_bytes: int | None
    estimated_required_bytes: int | None
    estimated_headroom_bytes: int | None
