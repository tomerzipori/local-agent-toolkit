    warnings: tuple[str, ...]


@dataclass(frozen=True)
class ModelCandidate:
    installed: InstalledModel
    running: RunningModel | None
    memory: ModelMemoryEstimate
    profile: str
    ranking_key: tuple[object, ...]
    reasons: tuple[str, ...]


@dataclass(frozen=True)
class Settings:
    model: str
    host: str
    num_ctx: int
    max_chars: int


@dataclass(frozen=True)
class ContextFile:
    path: Path
    relative_path: str
    size_bytes: int
    source: str


@dataclass(frozen=True)
class SkippedFile:
    path: Path
    relative_path: str
    category: str
    detail: str


@dataclass
class ContextCollection:
    text: str
